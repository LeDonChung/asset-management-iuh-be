# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=asset_management

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Admin Account Configuration
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@iuh.edu.vn
ADMIN_PASSWORD=Admin@123
ADMIN_FULLNAME=Administrator

# Application Configuration
PORT=3000
NODE_ENV=development

# SMTP Configuration (for forgot password feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Asset Management System
SMTP_FROM_EMAIL=noreply@assetmanagement.com
SUPPORT_EMAIL=support@assetmanagement.com

# Redis Configuration (for reset password tokens)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Upload Configuration
UPLOAD_DEST=uploads
MAX_FILE_SIZE=5242880

# Security Configuration
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS Configuration
FRONTEND_URL=http://localhost:3001
